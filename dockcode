#!/usr/bin/env bash
set -euo pipefail

# ─── Configuration ────────────────────────────────────────────────────────────
IMAGE_NAME="opencode-openrouter"
IMAGE_TAG="v1"
TEMPLATE="${IMAGE_NAME}:${IMAGE_TAG}"
DOCKCODE_CONFIG_DIR="${HOME}/.config/dockcode"
CONFIG_FILE="${DOCKCODE_CONFIG_DIR}/config"
SCRIPT_DIR="$(dirname "$(realpath "${BASH_SOURCE[0]}")")"

DEFAULT_OPENCODE_CONFIG="${DOCKCODE_CONFIG_DIR}/opencode.json"
DEFAULT_AUTH_CONFIG="${DOCKCODE_CONFIG_DIR}/auth.json"

# ─── Config file I/O ──────────────────────────────────────────────────────────
get_config() {
	local key="$1" default="${2-}"
	if [[ -f ${CONFIG_FILE} ]] && grep -q "^${key}=" "${CONFIG_FILE}" 2>/dev/null; then
		grep "^${key}=" "${CONFIG_FILE}" | head -1 | cut -d= -f2-
	else
		echo "${default}"
	fi
}

set_config() {
	local key="$1" value="$2"
	mkdir -p "${DOCKCODE_CONFIG_DIR}"
	if [[ -f ${CONFIG_FILE} ]] && grep -q "^${key}=" "${CONFIG_FILE}" 2>/dev/null; then
		sed -i "s|^${key}=.*|${key}=${value}|" "${CONFIG_FILE}"
	else
		printf '%s=%s\n' "${key}" "${value}" >>"${CONFIG_FILE}"
	fi
}

init_config() {
	if [[ ! -f ${CONFIG_FILE} ]]; then
		mkdir -p "${DOCKCODE_CONFIG_DIR}"
		printf 'OPENCODE_CONFIG=%s\nAUTH_CONFIG=%s\n' \
			"${DEFAULT_OPENCODE_CONFIG}" "${DEFAULT_AUTH_CONFIG}" \
			>"${CONFIG_FILE}"
	fi
}

# ─── Initialize config and resolve values ─────────────────────────────────────
init_config
OPENCODE_CONFIG="$(get_config OPENCODE_CONFIG "${DEFAULT_OPENCODE_CONFIG}")"
AUTH_CONFIG="$(get_config AUTH_CONFIG "${DEFAULT_AUTH_CONFIG}")"

# ─── Helpers ──────────────────────────────────────────────────────────────────
info() { echo "INFO: $*"; }
warn() { echo "WARNING: $*" >&2; }
error() { echo "ERROR: $*" >&2; }

prompt_choice() {
	local prompt="$1"
	shift
	local choice
	while true; do
		echo "" >&2
		echo "${prompt}" >&2
		local i=1
		for opt in "$@"; do
			echo "  ${i}) ${opt}" >&2
			((i++))
		done
		printf "\nChoice [1-%d]: " $# >&2
		read -r choice
		if [[ ${choice} =~ ^[0-9]+$ ]] && ((choice >= 1 && choice <= $#)); then
			echo "${choice}"
			return
		fi
		echo "Invalid choice. Enter 1-$#." >&2
	done
}

# ─── Sandbox listing ─────────────────────────────────────────────────────────
get_sandbox_names() {
	local sandbox_json
	sandbox_json=$(docker sandbox ls --json 2>/dev/null || echo '{"vms":[]}')

	if command -v jq >/dev/null 2>&1; then
		echo "${sandbox_json}" | jq -r '.vms[].name' 2>/dev/null
	else
		while IFS= read -r line; do
			local sname
			sname=$(echo "${line}" | grep -o '"name": *"[^"]*"' | sed 's/"name": *"//;s/"$//' || true)
			[[ -n ${sname} ]] && echo "${sname}"
		done < <(echo "${sandbox_json}" | tr ',' '\n')
	fi
}

# ─── Resolve config file ─────────────────────────────────────────────────────
# Args: resolve_config <target_path> <default_path> <label> <filename> <host_path>
resolve_config() {
	local target="$1" default="$2" label="$3" filename="$4" host_path="$5"

	if [[ -f ${target} ]]; then
		return
	fi

	mkdir -p "$(dirname "${target}")"
	local choice

	while true; do
		choice=$(prompt_choice \
			"No ${label} found at ${target}. Which would you like to use?" \
			"Copy project default (${filename})" \
			"Use host config (${host_path})" \
			"Copy host config to $(dirname "${target}") (${host_path})" \
			"Specify a custom path to use")
		case "${choice}" in
		1)
			if [[ ! -f ${default} ]]; then
				error "Project default not found."
				continue 2
			fi
			cp "${default}" "${target}"
			echo ""
			read -n 1 -s -r -p "Project default has been copied. " \
				"You may need to edit its content before continuing with launch. " \
				"Please do so now. " \
				"Press any key to continue..."
			;;
		2)
			if [[ ! -f ${host_path} ]]; then
				error "Host file not found: ${host_path}"
				continue 2
			fi
			handle_config_update "${label}" "${host_path}"
			;;
		3)
			if [[ ! -f ${host_path} ]]; then
				error "Host file not found: ${host_path}"
				continue 2
			fi
			cp "${host_path}" "${target}"
			;;
		4)
			local custom_path
			printf "Enter path: "
			read -r custom_path
			custom_path="${custom_path/#\~/${HOME}}"
			if [[ ! -f ${custom_path} ]]; then
				error "File not found: ${custom_path}"
				continue 2
			fi
			handle_config_update "${label}" "${custom_path}"
			;;
		*)
			error "invalid selection"
			continue 2
			;;
		esac
		break
	done
	info "Copied ${label} to ${target}"
}

# ─── Build image ──────────────────────────────────────────────────────────────
build_image() {
	info "Building custom sandbox image..."
	local build_ctx=""
	build_ctx=$(mktemp -d)
	trap "rm -rf \"${build_ctx}\"" EXIT
	cp "${OPENCODE_CONFIG}" "${build_ctx}/opencode.json"
	cp "${SCRIPT_DIR}/Dockerfile" "${build_ctx}/Dockerfile"
	docker build -t "${TEMPLATE}" "${build_ctx}"
}

# ─── Inject auth.json ─────────────────────────────────────────────────────────
inject_auth() {
	local auth_path="$1" sandbox_name="$2"
	local remote_dir="/home/agent/.local/share/opencode"

	docker sandbox exec "${sandbox_name}" bash -c "mkdir -p ${remote_dir}"
	docker sandbox exec -i "${sandbox_name}" bash -c "cat > ${remote_dir}/auth.json" <"${auth_path}"
	docker sandbox exec "${sandbox_name}" bash -c "chmod 600 ${remote_dir}/auth.json"
}

# ─── Create and run sandbox ───────────────────────────────────────────────────
create_sandbox() {
	local name="$1" workspace="$2"

	if ! docker context use desktop-linux >/dev/null 2>&1; then
		warn "Docker Desktop context 'desktop-linux' not found."
		warn "Make sure Docker Desktop is installed and running."
		exit 1
	fi

	build_image

	docker sandbox rm "${name}" 2>/dev/null || true

	info "Creating sandbox '${name}'..."
	docker sandbox create --name "${name}" -t "${TEMPLATE}" opencode "${workspace}"

	info "Configuring network bypass for OpenRouter..."
	docker sandbox network proxy "${name}" \
		--bypass-host api.openrouter.ai \
		--bypass-host openrouter.ai

	info "Injecting auth.json..."
	if grep -q "CHANGE-ME" "${AUTH_CONFIG}" 2>/dev/null; then
		warn "auth.json still contains placeholder API key (CHANGE-ME)."
		warn "Edit ${AUTH_CONFIG} to set your OpenRouter API key."
	fi
	inject_auth "${AUTH_CONFIG}" "${name}"

	echo ""
	echo "Sandbox '${name}' is ready."
	echo ""
	echo "  Workspace:  ${workspace}"
	echo "  Template:   ${TEMPLATE}"
	echo "  Config:     ${OPENCODE_CONFIG}"
	echo "  Auth:       ${AUTH_CONFIG}"
}

# ─── Show usage ───────────────────────────────────────────────────────────────
show_usage() {
	cat >&2 <<'EOF'
Usage: dockcode <command> [args...]

Commands:
  config show                          Print config file paths
  config update <key> <value>          Update a config value

      Keys:
        opencode.json    Path to opencode.json
        auth.json        Path to auth.json

  ls [--json]                          List existing sandboxes
  destroy [-n name]                    Destroy a sandbox
                                        (interactive if no flags given)

  launch [-n name] [-w workspace]      Launch or create a sandbox
                                        (interactive if no flags given)

      -n    Sandbox name (default: current directory name)
      -w    Workspace directory (default: current directory)

Options:
  -h, --help                           Show this help message
  --version                            Show version
EOF
	exit 1
}

# ═══════════════════════════════════════════════════════════════════════════════
# SUB-COMMANDS
# ═══════════════════════════════════════════════════════════════════════════════

handle_config_show() {
	echo "opencode.json     ${OPENCODE_CONFIG}"
	echo "auth.json         ${AUTH_CONFIG}"
}

handle_config_update() {
	local key="${1-}"
	local value="${2-}"

	if [[ -z ${key} ]] || [[ -z ${value} ]]; then
		error "Usage: dockcode config update <key> <value>"
		exit 1
	fi

	case "${key}" in
	opencode.json)
		value="${value/#\~/${HOME}}"
		set_config OPENCODE_CONFIG "${value}"
		;;
	auth.json)
		value="${value/#\~/${HOME}}"
		set_config AUTH_CONFIG "${value}"
		;;
	*)
		error "Unknown key: ${key}"
		error "Valid keys: opencode.json, auth.json"
		exit 1
		;;
	esac

	info "Updated ${key} = ${value}"
}

handle_ls() {
	if [[ ${1-} == "--json" ]]; then
		docker sandbox ls --json 2>/dev/null || echo '{"vms":[]}'
		return
	fi

	local sandbox_names=()
	while IFS= read -r sname; do
		[[ -n ${sname} ]] && sandbox_names+=("${sname}")
	done < <(get_sandbox_names)

	if [[ ${#sandbox_names[@]} -eq 0 ]]; then
		info "No sandboxes found."
		return
	fi

	echo ""
	echo "Sandboxes:"
	echo ""
	local i=1
	for sname in "${sandbox_names[@]}"; do
		echo "  ${i}) ${sname}"
		((i++))
	done
	echo ""
	echo "Total: ${#sandbox_names[@]}"
}

handle_destroy() {
	local name=""

	while [[ $# -gt 0 ]]; do
		case "$1" in
		-n)
			name="${2-}"
			if [[ -z ${name} ]]; then
				error "Flag -n requires a value."
				exit 1
			fi
			shift 2
			;;
		*)
			error "Unknown flag: $1"
			exit 1
			;;
		esac
	done

	if [[ -z ${name} ]]; then
		local sandbox_names=()
		while IFS= read -r sname; do
			[[ -n ${sname} ]] && sandbox_names+=("${sname}")
		done < <(get_sandbox_names)

		if [[ ${#sandbox_names[@]} -eq 0 ]]; then
			info "No sandboxes to destroy."
			return
		fi

		local menu_options=()
		for sname in "${sandbox_names[@]}"; do
			menu_options+=("${sname}")
		done

		local choice
		choice=$(prompt_choice "Which sandbox would you like to destroy?" "${menu_options[@]}")
		name="${sandbox_names[$((choice - 1))]}"
	fi

	printf "Are you sure you want to destroy sandbox '%s'? [y/N] " "${name}"
	local confirm
	read -r confirm
	if [[ ! ${confirm} =~ ^(y|Y|yes|Yes)$ ]]; then
		info "Aborted."
		return
	fi

	info "Destroying sandbox '${name}'..."
	docker sandbox rm "${name}"
	info "Sandbox '${name}' has been destroyed."
}

interactive_launch() {
	local sandbox_names=()
	while IFS= read -r sname; do
		[[ -n ${sname} ]] && sandbox_names+=("${sname}")
	done < <(get_sandbox_names)

	local menu_options=()
	for sname in "${sandbox_names[@]}"; do
		menu_options+=("Launch existing sandbox: ${sname}")
	done
	menu_options+=("Create a new sandbox")

	local choice
	choice=$(prompt_choice "What would you like to do?" "${menu_options[@]}")

	if ((choice <= ${#sandbox_names[@]})); then
		local selected="${sandbox_names[$((choice - 1))]}"
		info "Launching existing sandbox '${selected}'..."
		docker sandbox run "${selected}"
		return
	fi

	local name workspace
	printf "Sandbox name (default: current directory name): "
	read -r name
	if [[ -z ${name} ]]; then
		name="$(basename "$(pwd)" | tr '.' '-')"
	fi

	printf "Workspace path (default: current directory): "
	read -r workspace
	workspace="${workspace:-.}"
	workspace="${workspace/#\~/${HOME}}"
	if [[ ! -d ${workspace} ]]; then
		error "Workspace directory does not exist: ${workspace}"
		exit 1
	fi
	workspace="$(realpath "${workspace}")"

	resolve_config "${OPENCODE_CONFIG}" "${SCRIPT_DIR}/opencode.json" \
		"opencode.json" "opencode.json" "${HOME}/.config/opencode/opencode.json"
	resolve_config "${AUTH_CONFIG}" "${SCRIPT_DIR}/auth.example.json" \
		"auth.json" "auth.example.json" "${HOME}/.local/share/opencode/auth.json"

	create_sandbox "${name}" "${workspace}"
	read -n 1 -s -r -p "Press any key to launch OpenCode sandbox..."
	docker sandbox run "${name}"
}

handle_launch() {
	local name="" workspace="" has_flags=false

	while [[ $# -gt 0 ]]; do
		case "$1" in
		-n)
			has_flags=true
			name="${2-}" # Safely read with a fallback
			if [[ -z ${name} ]]; then
				error "Flag -n requires a value."
				exit 1
			fi
			shift 2
			;;
		-w)
			has_flags=true
			workspace="${2-}"
			if [[ -z ${workspace} ]]; then
				error "Flag -w requires a value."
				exit 1
			fi
			shift 2
			;;
		*)
			error "Unknown flag: $1"
			exit 1
			;;
		esac
	done

	if [[ ${has_flags} == false ]]; then
		interactive_launch
		return
	fi

	workspace="${workspace:-.}"
	if [[ ! -d ${workspace} ]]; then
		error "Workspace directory does not exist: ${workspace}"
		exit 1
	fi
	workspace="$(realpath "${workspace}")"

	if [[ -z ${name} ]]; then
		name="$(basename "${workspace}" | tr '.' '-')"
	fi

	# Check if sandbox already exists
	local existing
	if command -v jq >/dev/null 2>&1; then
		existing=$(docker sandbox ls --json 2>/dev/null |
			jq -e --arg n "${name}" 'any(.vms[]; .name == $n)' 2>/dev/null || true)
	else
		existing=$(docker sandbox ls --json 2>/dev/null |
			grep -o "\"name\": *\"${name}\"" || true)
	fi
	if [[ -n ${existing} ]]; then
		info "Launching existing sandbox '${name}'..."
		docker sandbox run "${name}"
		return
	fi

	# Resolve configs
	resolve_config "${OPENCODE_CONFIG}" "${SCRIPT_DIR}/opencode.json" \
		"opencode.json" "opencode.json" "${HOME}/.config/opencode/opencode.json"
	resolve_config "${AUTH_CONFIG}" "${SCRIPT_DIR}/auth.example.json" \
		"auth.json" "auth.example.json" "${HOME}/.local/share/opencode/auth.json"

	create_sandbox "${name}" "${workspace}"
	read -n 1 -s -r -p "Press any key to launch OpenCode sandbox..."
	docker sandbox run "${name}"
}

# ═══════════════════════════════════════════════════════════════════════════════
# COMMAND DISPATCH
# ═══════════════════════════════════════════════════════════════════════════════

case "${1-}" in
-h | --help)
	show_usage
	;;
--version)
	echo "dockcode v2alpha"
	;;
config)
	case "${2-}" in
	show) handle_config_show ;;
	update) handle_config_update "${3-}" "${4-}" ;;
	*) show_usage ;;
	esac
	;;
ls)
	shift
	handle_ls "$@"
	;;
destroy)
	shift
	handle_destroy "$@"
	;;
launch)
	shift
	handle_launch "$@"
	;;
*)
	show_usage
	;;
esac
